<idea-plugin>
    <id>co.anbora.labs.nushell.community</id>
    <name>NuShell Community</name>
    <vendor email="support@anbora.co" url="https://labs.anbora.co">Anbora-labs</vendor>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.NuShellBundle</resource-bundle>

    <!-- Extension points defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensionPoints>
        <extensionPoint
            name="configurableProvider"
            interface="co.anbora.labs.nushell.community.ide.settings.NuShellConfigurableProvider"
            dynamic="true"/>
        <extensionPoint
            name="parserDefinition"
            interface="co.anbora.labs.nushell.community.lang.core.parser.NuParserDefinition"
            dynamic="true"/>
    </extensionPoints>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="NuShell" implementationClass="co.anbora.labs.nushell.community.lang.NuShellFileType"
                  fieldName="INSTANCE" language="NuShell" extensions="nu"/>

        <lang.syntaxHighlighterFactory language="NuShell"
                                       implementationClass="co.anbora.labs.nushell.community.ide.highlight.NuSyntaxHighlighterFactory"/>
        <lang.parserDefinition language="NuShell" implementationClass="co.anbora.labs.nushell.community.lang.core.parser.NuParserDefinitionProxy"/>
        <lang.commenter language="NuShell" implementationClass="co.anbora.labs.nushell.community.ide.commenter.NuCommenter"/>
        <lang.braceMatcher language="NuShell" implementationClass="co.anbora.labs.nushell.community.ide.typing.NuShellBraceMatcher"/>
        <quoteHandler fileType="NuShell" className="co.anbora.labs.nushell.community.ide.editor.NuQuoteHandler"/>
        <colorSettingsPage implementation="co.anbora.labs.nushell.community.ide.color.NuShellColorSettingPage"/>

        <applicationConfigurable
            provider="co.anbora.labs.nushell.community.ide.settings.NuShellSettingsConfigurableProvider"
            id="co.anbora.labs.nushell.community.settings"
            key="nushell.settings.display.name"
            bundle="messages.NuShellBundle"/>
    </extensions>

    <extensions defaultExtensionNs="co.anbora.labs.nushell.community">
        <parserDefinition implementation="co.anbora.labs.nushell.community.lang.core.parser.NuShellParserDefinition"/>
    </extensions>
</idea-plugin>